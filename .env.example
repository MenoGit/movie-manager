# TMDb API — get free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# qBittorrent Web UI (default port 8080, check your setup)
QBIT_URL=http://host.docker.internal:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin

# Prowlarr (spun up via Docker in this compose)
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here  # set after first Prowlarr boot

# Plex
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=your_plex_token_here  # Settings > Troubleshooting > Copy to Clipboard in Plex

# Where movies go on the server (must be accessible by qBittorrent)
MOVIES_PATH=/mnt/media/movies
